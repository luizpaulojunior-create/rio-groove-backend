PORT=3000
NODE_ENV=production

FRONTEND_URL=https://store.riogroovemovimentos.com.br
STORE_URL=https://store.riogroovemovimentos.com.br
BACKEND_URL=https://seu-backend.onrender.com

# Supabase → Settings → API (projeto cvpobvvkhcqasumhfwps)
# Use as chaves NOVAS — chaves legacy (eyJ…) foram desabilitadas.
SUPABASE_URL=https://cvpobvvkhcqasumhfwps.supabase.co
# Publishable — mesma chave do admin (VITE_SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
# Secret — só backend/Render; nunca no frontend
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxx
# Aliases aceitos pelo backend (use um dos três):
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxx
# SB_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxx

MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-seu_access_token_aqui
MERCADO_PAGO_WEBHOOK_SECRET=

# Opcional — observabilidade (S2)
SENTRY_DSN=

MELHOR_ENVIO_TOKEN=seu_melhor_envio_token_aqui
MELHOR_ENVIO_SANDBOX=false
MELHOR_ENVIO_ORIGIN_CEP=22723019
# Chave NF-e (44 dígitos) para envios comerciais com remetente CNPJ (obrigatório na J&T)
# MELHOR_ENVIO_INVOICE_KEY=
# MELHOR_ENVIO_MIN_INSURANCE_VALUE=5
# MELHOR_ENVIO_REQUIRE_INVOICE_FOR_CNPJ=false
# Opcional — API interna do site Melhor Rastreio (sem cadastro público; normalmente deixar vazio)
# MELHOR_RASTREIO_GRAPHQL_TOKEN=

SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_usuario_smtp
SMTP_PASSWORD=sua_senha_smtp
EMAIL_FROM=noreply@riogroovemovimentos.com.br
RESEND_API_KEY=seu_token_resend
WHATSAPP_ZAPI_URL=https://api.z-api.io/instances/SEU_INSTANCE/token/SEU_TOKEN/send-text
WHATSAPP_ZAPI_TOKEN=seu_token_zapi
WHATSAPP_DEFAULT_COUNTRY=55

STATEMENT_DESCRIPTOR=RIO GROOVE
DEFAULT_CURRENCY=BRL

# Google Analytics 4 (opcional — funil no admin + Measurement Protocol)
GA4_PROPERTY_ID=539502234
GA4_MEASUREMENT_ID=G-2J23RT1MN3
# Admin → Fluxo de dados → Measurement Protocol API secrets
GA4_API_SECRET=
# JSON da conta de serviço (texto ou base64) — ver ENVIRONMENT.md
GA4_SERVICE_ACCOUNT_JSON=
# GA4_MP_DEBUG=true envia para o endpoint de validação do Google
