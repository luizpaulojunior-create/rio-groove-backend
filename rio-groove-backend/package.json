{
  "name": "rio-groove-backend",
  "version": "2.0.0",
  "description": "Backend da Rio Groove Store com Node.js, Express, Supabase e Mercado Pago Checkout Pro",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "node --check src/app.js && node --check src/server.js",
    "test": "node --test --require ./test/setup-env.js test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sentry/node": "^9.47.1",
    "@supabase/supabase-js": "^2.105.4",
    "body-parser": "^2.2.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "mercadopago": "^2.3.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.4",
    "pg": "^8.21.0",
    "ws": "^8.20.1"
  }
}
